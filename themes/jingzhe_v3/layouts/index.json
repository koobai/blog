{{- $laodaoPages := where .Site.RegularPages "Section" "laodao" -}}
{{- $index := slice -}}
{{- range $laodaoPages -}}
  {{- if .Plain -}}
    {{- /* 修改时间格式，并新增 permalink 字段 */ -}}
    {{- $index = $index | append (dict "content" .Plain "date" (.Date.Format "2006-01-02 15:04") "permalink" .Permalink) -}}
  {{- end -}}
{{- end -}}
{{- $index | jsonify -}}