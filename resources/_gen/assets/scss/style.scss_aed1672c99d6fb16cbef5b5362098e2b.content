  font-size: 1rem;
  cursor: pointer; }
  @media (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) .admin-cancel, html:not([data-theme="light"]) .admin-modify {
      color: var(--text-highlight-dark-color); } }
  html[data-theme="dark"] .admin-cancel, html[data-theme="dark"] .admin-modify {
    color: var(--text-highlight-dark-color); }
  .admin-cancel:hover,
  .admin-modify:hover {
