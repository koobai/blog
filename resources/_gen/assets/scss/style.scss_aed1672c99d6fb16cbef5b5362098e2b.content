        color: var(--text-info-color); }
        @media (prefers-color-scheme: dark) {
          html:not([data-theme="light"]) .bento-calendar-board .globalSection .metricBlock .metricLabel {
            color: var(--text-info-dark-color); } }
        html[data-theme="dark"] .bento-calendar-board .globalSection .metricBlock .metricLabel {
          color: var(--text-info-dark-color); }
      .bento-calendar-board .globalSection .metricBlock .metricValue {
