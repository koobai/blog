      transition: color 0.2s ease; }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme="light"]) .bento-calendar-board .monthNav button {
          color: var(--text-info-dark-color); } }
      html[data-theme="dark"] .bento-calendar-board .monthNav button {
        color: var(--text-info-dark-color); }
      .bento-calendar-board .monthNav button svg {
