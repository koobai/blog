.admin-btn-delete {
  color: var(--text-info-color) !important; }
  @media (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) .admin-btn-delete {
      color: var(--text-info-dark-color) !important; } }
  html[data-theme="dark"] .admin-btn-delete {
    color: var(--text-info-dark-color) !important; }

.admin-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.65);
