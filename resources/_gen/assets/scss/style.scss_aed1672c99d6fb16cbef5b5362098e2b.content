  .bento-calendar-board .ai-toggle-btn {
    position: absolute;
    right: 0;
    color: var(--exercise-text-highlight-color) !important;
    border-radius: 8px !important;
    padding: 4px 6px !important;
    transition: all 0.3s ease !important; }
    .bento-calendar-board .ai-toggle-btn.active {
      background: var(--exercise-text-highlight-color) !important;
      color: #fff !important; }
    .bento-calendar-board .ai-toggle-btn svg {
      width: 18px !important;
      height: 18px !important; }
  .bento-calendar-board .cal-content-wrapper {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    position: relative; }
  .bento-calendar-board .calendar-grid-view {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    width: 100%; }
  .bento-calendar-board .ai-insight-view {
    flex: 1;
    padding: 0 4px;
    background: transparent;
    /* 去掉所有背景色和渐变 */
