    text-align-last: left;
    text-justify: inter-ideograph;
    word-break: break-word;
    overflow-wrap: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden; }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) .page-blog-list .featured-posts .post-summary {
        color: var(--text-content-dark-color); } }
    html[data-theme="dark"] .page-blog-list .featured-posts .post-summary {
      color: var(--text-content-dark-color); }

.page-blog-list .secondary-posts {
  display: grid;
  gap: 10px;
  margin-top: 30px; }
  @media (min-width: 768px) {
    .page-blog-list .secondary-posts {
