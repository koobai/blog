      html:not([data-theme="light"]) .bento-calendar-board .globalSection, html:not([data-theme="light"]) .bento-calendar-board .calendarSection, html:not([data-theme="light"]) .bento-calendar-board .insightCard {
        background: var(--background-card-dark-color);
        border: 1px solid var(--background-card-border-dark-color); } }
    html[data-theme="dark"] .bento-calendar-board .globalSection, html[data-theme="dark"] .bento-calendar-board .calendarSection, html[data-theme="dark"] .bento-calendar-board .insightCard {
      background: var(--background-card-dark-color);
