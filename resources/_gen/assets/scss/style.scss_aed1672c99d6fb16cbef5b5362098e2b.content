  @media (min-width: 768px) and (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) .page-bowen-admin .floating-header {
      opacity: 0.4; } }
  @media (min-width: 768px) {
      html[data-theme="dark"] .page-bowen-admin .floating-header {
        opacity: 0.4; } }
.page-bowen-admin .admin-immersive-wrapper {
  max-width: 800px;
  margin-bottom: 100px;
  margin: 30px auto 40px; }
  @media (min-width: 768px) {
    .page-bowen-admin .admin-immersive-wrapper {
      margin: 5vh auto 160px; } }
/* 2. 头部信息区布局重置 */
.page-bowen-admin .admin-publish-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: space-between;
  align-items: center;
  visibility: visible; }

.page-bowen-admin .write-header-container {
  display: block; }

.write-header {
  display: flex;
