  transition: color 0.2s ease;
  color: var(--text-info-color); }
  .admin-input-btn:hover {
    opacity: 0.8; }
  @media (prefers-color-scheme: dark) {
    html:not([data-theme="light"]) .admin-input-btn {
      color: var(--text-info-dark-color); } }
  html[data-theme="dark"] .admin-input-btn {
    color: var(--text-info-dark-color); }

.admin-popup-footer {
