    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) .page-blog-list .featured-posts .post-cover {
        background: rgba(255, 255, 255, 0.02); } }
    html[data-theme="dark"] .page-blog-list .featured-posts .post-cover {
